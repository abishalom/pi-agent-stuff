{
  "name": "pi-agent-stuff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Pi package with utility extensions, selected upstream extensions, reusable skills, prompts, and upstream interactive subagents with local model/thinking overrides.",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./pi-extension/notify-finished/index.ts",
      "./pi-extension/session-changed-files/index.ts",
      "./pi-extension/prompt-stash/index.ts",
      "./pi-extension/answer/index.ts",
      "./node_modules/mitsupi/extensions/todos.ts",
      "./node_modules/mitsupi/extensions/files.ts",
      "./node_modules/pi-interactive-subagents/pi-extension/subagents/index.ts",
      "./node_modules/pi-interactive-subagents/pi-extension/session-artifacts/index.ts",
      "./pi-extension/diff-review/index.ts",
      "./pi-extension/subagent-model-overrides/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/mitsupi/skills/uv/SKILL.md"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "test": "node --test",
    "build:diff-review-web": "node -e \"console.error('build:diff-review-web not implemented yet (Task 5 will add the real pipeline)'); process.exit(1)\"",
    "verify:diff-review-web": "node -e \"console.error('verify:diff-review-web not implemented yet (Task 5 will add the real pipeline)'); process.exit(1)\""
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.22",
    "@pierre/trees": "^1.0.0-beta.3",
    "glimpseui": "^0.6.2",
    "mitsupi": "^1.6.0",
    "pi-interactive-subagents": "github:HazAT/pi-interactive-subagents",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  }
}
