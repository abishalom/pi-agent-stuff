{
  "name": "pi-agent-stuff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Pi package with utility extensions, reusable skills, prompts, and upstream interactive subagents with local model/thinking overrides.",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": [
      "./pi-extension/notify-finished/index.ts",
      "./pi-extension/session-changed-files/index.ts",
      "./node_modules/pi-interactive-subagents/pi-extension/subagents/index.ts",
      "./node_modules/pi-interactive-subagents/pi-extension/session-artifacts/index.ts",
      "./pi-extension/subagent-model-overrides/index.ts"
    ],
    "skills": ["./skills"],
    "prompts": ["./prompts"]
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "pi-interactive-subagents": "github:HazAT/pi-interactive-subagents"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
